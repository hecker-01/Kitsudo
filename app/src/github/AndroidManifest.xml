<?xml version="1.0" encoding="utf-8" ?>
<!--
    GitHub / sideload flavor. Adds the permissions the in-app self-updater
    needs to download and install APKs from GitHub releases. These are
    deliberately absent from the Play flavor, where updates go through the
    Play Store.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- Storage write only needed below API 29 for saving the APK to Downloads. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"
    />

</manifest>
